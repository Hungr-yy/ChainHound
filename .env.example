# Which connector the CLI uses: blockstream (default, no creds) or bigquery
CHAINHOUND_PROVIDER=blockstream
# For the bigquery connector:
CHAINHOUND_GCP_PROJECT=
# Optional Postgres persistence:
CHAINHOUND_DATABASE_URL=postgresql://localhost/chainhound
# Override the OFAC SDN source URL (optional):
CHAINHOUND_OFAC_URL=
# TagPack corpus path (tarball or checked-out repo dir); defaults to
# data/labels/tagpacks.tar.gz:
CHAINHOUND_TAGPACKS_PATH=
# Chainabuse API key (required for `labels check --source chainabuse`):
CHAINHOUND_CHAINABUSE_KEY=
